#include <dt-bindings/zmk/mouse.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/backlight.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/rgb.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  Q  |  W  |  E  |  R  |  T  |   |  Y  |  U   |  I  |  O  |  P  | BSPC |
            // | CTRL |  A  |  S  |  D  |  F  |  G  |   |  H  |  J   |  K  |  L  |  ;  |  '   |
            // | SHFT |  Z  |  X  |  C  |  V  |  B  |   |  N  |  M   |  ,  |  .  |  /  | ESC  |
            //                    | GUI | LWR | SPC |   | ENT | RSE  | ALT |

            bindings = <
&kp ESC    &kp Q  &kp W  &kp E      &kp R  &kp T        &kp Y          &kp U  &kp I         &kp O    &kp P     &kp BSPC
&kp TAB    &kp A  &kp S  &kp D      &kp F  &kp G        &kp H          &kp J  &kp K         &kp L    &kp SEMI  &kp ENTER
&kp LSHFT  &kp Z  &kp X  &kp C      &kp V  &kp B        &kp N          &kp M  &kp COMMA     &kp DOT  &kp FSLH  &kp RIGHT_SHIFT
                         &kp LCTRL  &mo 1  &kp SPACE    &kp RIGHT_ALT  &mo 2  &kp LEFT_WIN
            >;
        };

        lower_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  1  |  2  |  3  |  4  |  5  |   |  6  |  7  |  8  |  9  |  0  | BSPC |
            // | BTCLR| BT1 | BT2 | BT3 | BT4 | BT5 |   | LFT | DWN |  UP | RGT |     |      |
            // | SHFT |     |     |     |     |     |   |     |     |     |     |     |      |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            bindings = <
<<<<<<< HEAD
&kp GRAVE       &kp NUMBER_1  &kp NUMBER_2    &kp NUMBER_3      &kp NUMBER_4       &kp N5               &kp NUMBER_6    &kp N7          &kp N8        &kp MINUS      &kp EQUAL  &kp DEL
&kp CAPS        &kp LPAR      &kp RPAR        &kp LEFT_BRACKET  &kp RIGHT_BRACKET  &kp C_VOLUME_UP      &kp LEFT_ARROW  &kp DOWN_ARROW  &kp UP_ARROW  &kp RIGHT      &kp SQT    &kp BSLH
&kp LEFT_SHIFT  &none         &kp C_PREVIOUS  &kp C_PLAY_PAUSE  &kp C_NEXT         &kp C_VOLUME_DOWN    &kp HOME        &kp END         &kp PAGE_UP   &kp PAGE_DOWN  &none      &kp RIGHT_SHIFT
                                              &kp LCTRL         &trans             &kp SPACE            &kp RIGHT_ALT   &mo 3           &kp LEFT_WIN
=======
&kp GRAVE       &kp NUMBER_1  &kp NUMBER_2    &kp NUMBER_3      &kp NUMBER_4       &kp N5               &kp NUMBER_6   &kp N7          &kp N8          &kp MINUS  &kp EQUAL  &kp DEL
&kp CAPS        &kp LPAR      &kp RPAR        &kp LEFT_BRACKET  &kp RIGHT_BRACKET  &kp C_VOLUME_UP      &kp HOME       &kp LEFT_ARROW  &kp UP_ARROW    &kp RIGHT  &kp SQT    &kp BSLH
&kp LEFT_SHIFT  &none         &kp C_PREVIOUS  &kp C_PLAY_PAUSE  &kp C_NEXT         &kp C_VOLUME_DOWN    &kp END        &none           &kp DOWN_ARROW  &none      &none      &kp RIGHT_SHIFT
                                              &kp LCTRL         &trans             &kp SPACE            &kp RIGHT_ALT  &mo 3           &kp LEFT_WIN
>>>>>>> parent of b08669e (Better arrow key placement)
            >;
        };

        raise_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  !  |  @  |  #  |  $  |  %  |   |  ^  |  &  |  *  |  (  |  )  | BSPC |
            // | CTRL |     |     |     |     |     |   |  -  |  =  |  [  |  ]  |  \  |  `   |
            // | SHFT |     |     |     |     |     |   |  _  |  +  |  {  |  }  | "|" |  ~   |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            bindings = <
&kp ESC         &trans  &trans  &trans     &trans  &trans       &kp KP_DIVIDE    &kp KP_NUMBER_7  &kp KP_NUMBER_8  &kp KP_NUMBER_9  &kp KP_MULTIPLY  &kp DEL
<<<<<<< HEAD
&kp CAPSLOCK    &trans  &trans  &trans     &trans  &trans       &kp KP_SUBTRACT  &kp KP_NUMBER_4  &kp KP_NUMBER_5  &kp KP_NUMBER_6  &kp KP_PLUS      &kp KP_NUMLOCK
=======
&kp CAPSLOCK    &trans  &trans  &trans     &trans  &trans       &kp KP_SUBTRACT  &kp KP_NUMBER_4  &kp KP_NUMBER_5  &kp KP_NUMBER_6  &kp KP_PLUS      &none
>>>>>>> parent of b08669e (Better arrow key placement)
&kp LEFT_SHIFT  &trans  &trans  &trans     &trans  &trans       &kp KP_NUMBER_0  &kp KP_NUMBER_1  &kp KP_NUMBER_2  &kp KP_NUMBER_3  &kp KP_DOT       &none
                                &kp LCTRL  &mo 3   &kp SPACE    &kp RIGHT_ALT    &trans           &kp LEFT_WIN
            >;
        };

        dual_mod {
            bindings = <
&kp ESC                         &kp F1                           &kp F2                             &kp F3                             &kp F4           &kp F5             &kp F6         &kp F7           &kp F8           &kp F9             &kp F10  &kp F11
&bt BT_CLR                      &bt BT_SEL 0                     &bt BT_SEL 1                       &bt BT_SEL 2                       &bt BT_SEL 3     &bt BT_SEL 4       &bl BL_ON      &rgb_ug RGB_EFF  &rgb_ug RGB_SPI  &ext_power EP_ON   &kp F12  &kp F13
&rgb_ug RGB_COLOR_HSB(0,0,100)  &rgb_ug RGB_COLOR_HSB(0,100,50)  &rgb_ug RGB_COLOR_HSB(122,100,50)  &rgb_ug RGB_COLOR_HSB(237,100,50)  &rgb_ug RGB_BRI  &rgb_ug RGB_BRD    &bl BL_OFF     &rgb_ug RGB_EFR  &rgb_ug RGB_SPD  &ext_power EP_OFF  &kp F14  &kp F15
                                                                                                    &kp LCTRL                          &trans           &kp SPACE          &kp RIGHT_ALT  &trans           &kp LEFT_WIN
            >;
        };
    };
};

&led_strip { chain-length = <27>; };
